# macOS
.DS_Store

# Swift
.build/
Packages/
# SwiftPM derived state — ignore per-user and resolution caches only
# Shared schemes (.swiftpm/xcode/xcshareddata/xcschemes/) are committed intentionally
.swiftpm/manifest/
.swiftpm/checkouts/
.swiftpm/repositories/
.swiftpm/xcode/xcuserdata/

# Node
node_modules/
dist/
.pnpm-store/

# Python
.venv/
__pycache__/
.pytest_cache/

# Secrets and local config
.env

# Claude Code session artifacts (lock files, not definitions)
.claude/scheduled_tasks.lock
.env.local
*.p12
*.pfx
*.key
*.pem

# Data
runtime-data/
coverage/
HealthOS/Constructor/Steward/providers/providers.local.json
HealthOS/Constructor/Steward/providers/*.local.json
*.env
runtime-data/steward/model-invocations.jsonl

# Steward generated/derived construction artifacts
HealthOS/Constructor/Steward/memory/derived/*
!HealthOS/Constructor/Steward/memory/derived/README.md
HealthOS/Constructor/Steward/prompts/generated/*
!HealthOS/Constructor/Steward/prompts/generated/README.md

# Xcode per-user workspace state
xcuserdata/
*.xcuserstate
