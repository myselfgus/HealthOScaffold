# macOS
.DS_Store

# Swift
.build/
Packages/
# SwiftPM derived state — ignore per-user and resolution caches only
# Shared schemes (.swiftpm/xcode/xcshareddata/xcschemes/) are committed intentionally
.swiftpm/manifest/
.swiftpm/checkouts/
.swiftpm/repositories/
.swiftpm/xcode/xcuserdata/

# Node
node_modules/
dist/
.pnpm-store/

# Python
.venv/
__pycache__/
.pytest_cache/

# Secrets and local config
.env

# Claude Code session artifacts (lock files, not definitions)
.claude/scheduled_tasks.lock
.env.local
*.p12
*.pfx
*.key
*.pem

# Data
runtime-data/
coverage/
.healthos-steward/providers/providers.local.json
.healthos-steward/providers/*.local.json
*.env
runtime-data/steward/model-invocations.jsonl

# Steward generated/derived construction artifacts
.healthos-steward/memory/derived/*
!.healthos-steward/memory/derived/README.md
.healthos-steward/prompts/generated/*
!.healthos-steward/prompts/generated/README.md

# Xcode per-user workspace state
xcuserdata/
*.xcuserstate
