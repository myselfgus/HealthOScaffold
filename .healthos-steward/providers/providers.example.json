{
  "version": "0.2.0",
  "providers": [
    {
      "id": "openai-default",
      "kind": "openai",
      "enabled": false,
      "model": "configured-openai-model",
      "apiKeyEnv": "OPENAI_API_KEY",
      "endpointMode": "responses",
      "baseUrl": "https://api.openai.com/v1",
      "timeoutMs": 120000,
      "maxOutputTokens": 4096,
      "temperature": 0.2,
      "dryRunDefault": true,
      "supportsPrReview": true,
      "supportsNextTask": true,
      "supportsHandoff": true,
      "supportsStructuredJson": true,
      "supportsToolUse": false,
      "notes": "OpenAI Responses API. Model must be configured and available to your account."
    },
    {
      "id": "anthropic-default",
      "kind": "anthropic",
      "enabled": false,
      "model": "configured-anthropic-model",
      "apiKeyEnv": "ANTHROPIC_API_KEY",
      "endpointMode": "messages",
      "baseUrl": "https://api.anthropic.com/v1",
      "anthropicVersion": "2023-06-01",
      "timeoutMs": 120000,
      "maxOutputTokens": 4096,
      "temperature": 0.2,
      "dryRunDefault": true,
      "supportsPrReview": true,
      "supportsNextTask": true,
      "supportsHandoff": true,
      "supportsStructuredJson": true,
      "supportsToolUse": false,
      "notes": "Anthropic Messages API with required anthropic-version header."
    },
    {
      "id": "xai-default",
      "kind": "xai",
      "enabled": false,
      "model": "configured-xai-model",
      "apiKeyEnv": "XAI_API_KEY",
      "endpointMode": "responses",
      "baseUrl": "https://api.x.ai/v1",
      "timeoutMs": 120000,
      "maxOutputTokens": 4096,
      "temperature": 0.2,
      "dryRunDefault": true,
      "supportsPrReview": true,
      "supportsNextTask": true,
      "supportsHandoff": true,
      "supportsStructuredJson": true,
      "supportsToolUse": false,
      "notes": "xAI Responses API preferred; chatCompletions may be used as explicit fallback."
    },
    {
      "id": "disabled-default",
      "kind": "disabled",
      "enabled": false,
      "model": "none",
      "endpointMode": "responses",
      "timeoutMs": 1000,
      "dryRunDefault": true,
      "supportsPrReview": false,
      "supportsNextTask": false,
      "supportsHandoff": false,
      "supportsStructuredJson": false,
      "supportsToolUse": false,
      "notes": "Fail-closed placeholder when no LLM provider is configured."
    }
  ]
}
