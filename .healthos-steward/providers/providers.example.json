{
  "version": "0.1.0",
  "providers": [
    {
      "id": "openai-default",
      "kind": "openai",
      "enabled": false,
      "model": "configured-openai-model",
      "apiKeyEnv": "OPENAI_API_KEY",
      "endpointMode": "responses",
      "baseUrl": "https://api.openai.com/v1",
      "timeoutMs": 120000,
      "maxOutputTokens": 4096,
      "temperature": 0.2,
      "dryRunDefault": true,
      "supportsPrReview": true,
      "supportsNextTask": true,
      "supportsHandoff": true,
      "supportsStructuredJson": true,
      "supportsToolUse": false,
      "notes": "Use a model available to your account."
    },
    {
      "id": "anthropic-default",
      "kind": "anthropic",
      "enabled": false,
      "model": "configured-anthropic-model",
      "apiKeyEnv": "ANTHROPIC_API_KEY",
      "endpointMode": "messages",
      "baseUrl": "https://api.anthropic.com/v1",
      "anthropicVersion": "2023-06-01",
      "timeoutMs": 120000,
      "maxOutputTokens": 4096,
      "temperature": 0.2,
      "dryRunDefault": true,
      "supportsPrReview": true,
      "supportsNextTask": true,
      "supportsHandoff": true,
      "supportsStructuredJson": true,
      "supportsToolUse": false,
      "notes": "Requires anthropic-version header."
    },
    {
      "id": "xai-default",
      "kind": "xai",
      "enabled": false,
      "model": "configured-xai-model",
      "apiKeyEnv": "XAI_API_KEY",
      "endpointMode": "responses",
      "baseUrl": "https://api.x.ai/v1",
      "timeoutMs": 120000,
      "maxOutputTokens": 4096,
      "temperature": 0.2,
      "dryRunDefault": true,
      "supportsPrReview": true,
      "supportsNextTask": true,
      "supportsHandoff": true,
      "supportsStructuredJson": true,
      "supportsToolUse": false,
      "notes": "Responses first; chatCompletions only as explicit fallback."
    },
    {
      "id": "codex-cli-default",
      "kind": "codex-cli",
      "enabled": false,
      "model": "local-codex-cli",
      "endpointMode": "localCommand",
      "timeoutMs": 30000,
      "dryRunDefault": true,
      "supportsPrReview": true,
      "supportsNextTask": true,
      "supportsHandoff": true,
      "supportsStructuredJson": false,
      "supportsToolUse": false,
      "command": ["healthos-steward", "delegate", "--target", "codex", "--task", "next", "--dry-run"],
      "commandAllowlist": [["healthos-steward", "delegate"]],
      "notes": "Dry-run by default; explicit execution needed for real delegation."
    },
    {
      "id": "claude-code-cli-default",
      "kind": "claude-code-cli",
      "enabled": false,
      "model": "local-claude-code-cli",
      "endpointMode": "localCommand",
      "timeoutMs": 30000,
      "dryRunDefault": true,
      "supportsPrReview": true,
      "supportsNextTask": true,
      "supportsHandoff": true,
      "supportsStructuredJson": false,
      "supportsToolUse": false,
      "command": ["healthos-steward", "delegate", "--target", "claude", "--task", "next", "--dry-run"],
      "commandAllowlist": [["healthos-steward", "delegate"]],
      "notes": "Dry-run by default; explicit execution needed for real delegation."
    }
  ]
}
