{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://healthos.local/HealthOS/Tier1-Mestral-Core/Schemas/steward/territory.schema.json",
  "title": "HealthOS Territory Record",
  "description": "Construction-system metadata for bounded repository domains. Territory records guide Steward and Settlers but do not replace official docs or authorize runtime behavior.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "summary",
    "maturity",
    "canonicalDocs",
    "primaryPaths",
    "secondaryPaths",
    "forbiddenPaths",
    "invariants",
    "allowedWork",
    "forbiddenWork",
    "validationCommands",
    "knownGaps",
    "defaultSettlerIds",
    "relatedTerritoryIds",
    "notes"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "maturity": {
      "type": "string",
      "enum": [
        "doctrine-only",
        "scaffolded contract",
        "implemented seam",
        "tested operational path",
        "production-hardened"
      ]
    },
    "canonicalDocs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "primaryPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "secondaryPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbiddenPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "invariants": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowedWork": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbiddenWork": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validationCommands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "knownGaps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "defaultSettlerIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "relatedTerritoryIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
