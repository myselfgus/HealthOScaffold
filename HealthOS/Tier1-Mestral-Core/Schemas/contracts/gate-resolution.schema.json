{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "healthos/contracts/gate-resolution",
  "type": "object",
  "required": ["id", "gateRequestId", "resolverUserId", "resolverRole", "resolution", "reviewedAt"],
  "properties": {
    "id": {"type": "string", "format": "uuid"},
    "gateRequestId": {"type": "string", "format": "uuid"},
    "resolverUserId": {"type": "string", "format": "uuid"},
    "resolverRole": {"type": "string"},
    "resolution": {
      "type": "string",
      "enum": ["approved", "rejected", "cancelled"]
    },
    "rationaleNote": {"type": ["string", "null"]},
    "reviewedAt": {"type": "string", "format": "date-time"},
    "signatureRef": {"type": ["string", "null"]}
  }
}
