{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "healthos/contracts/soap-draft-document",
  "type": "object",
  "required": ["draft", "sections", "contextStatus", "contextSummary", "noteSummary"],
  "properties": {
    "draft": {"$ref": "artifact-draft.schema.json"},
    "sections": {
      "type": "object",
      "required": ["subjective", "objective", "assessment", "plan"],
      "properties": {
        "subjective": {"type": "string"},
        "objective": {"type": "string"},
        "assessment": {"type": "string"},
        "plan": {"type": "string"}
      }
    },
    "contextStatus": {
      "type": "string",
      "enum": ["ready", "partial", "empty", "degraded"]
    },
    "contextSummary": {"type": "string"},
    "noteSummary": {"type": "string"}
  }
}
