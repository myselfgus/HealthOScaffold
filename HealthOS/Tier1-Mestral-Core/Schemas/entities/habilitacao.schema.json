{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "healthos/entities/habilitacao",
  "type": "object",
  "required": ["id", "usuarioId", "servicoId", "registroProfissionalId", "abertaEm"],
  "properties": {
    "id": {"type": "string", "format": "uuid"},
    "usuarioId": {"type": "string", "format": "uuid"},
    "servicoId": {"type": "string", "format": "uuid"},
    "registroProfissionalId": {"type": "string", "format": "uuid"},
    "abertaEm": {"type": "string", "format": "date-time"},
    "fechadaEm": {"type": ["string", "null"], "format": "date-time"},
    "contexto": {"type": "object"}
  }
}
