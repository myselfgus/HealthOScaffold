{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://healthos.dev/schemas/governed-operational-spec-review-record.schema.json",
  "title": "Governed Operational Spec Review Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "spec_id",
    "bundle_id",
    "reviewer_id",
    "reviewer_role",
    "rationale",
    "reviewed_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "spec_id": {
      "type": "string",
      "minLength": 1
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewer_id": {
      "type": "string",
      "minLength": 1
    },
    "reviewer_role": {
      "type": "string",
      "minLength": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
