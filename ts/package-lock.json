    "node_modules/@healthos/runtime-async": {
      "resolved": "packages/runtime-async",
      "link": true
    },
    "node_modules/@healthos/runtime-user-agent": {
      "resolved": "packages/runtime-user-agent",
      "link": true
    },
    "node_modules/@types/node": {
      "version": "22.19.17",
      "dev": true,
      "license": "MIT",
      "dependencies": {
        "undici-types": "~6.21.0"
      }
    },
    "node_modules/ajv": {
      "version": "8.18.0",
      "license": "MIT",
      "dependencies": {
        "fast-deep-equal": "^3.1.3",
