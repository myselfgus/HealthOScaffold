    "node_modules/fast-deep-equal": {
      "version": "3.1.3",
      "license": "MIT"
    },
    "node_modules/fast-uri": {
      "version": "3.1.0",
      "funding": [
        {
          "type": "github",
          "url": "https://github.com/sponsors/fastify"
        },
        {
          "type": "opencollective",
